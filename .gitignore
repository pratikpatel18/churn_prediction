# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.so
venv/
venv_local/


# ── Data files (too large for Git) ────────────────
data/raw/*.csv
data/processed/*.parquet
data/reference/*.parquet

# ── Model artifacts (too large, stored in MLflow) ─
artifacts/models/*.joblib
artifacts/models/*.pkl
artifacts/models/*.json
artifacts/mlflow/

# ── MLflow local storage ──────────────────────────
mlruns/
mlflow.db

# ── Airflow runtime files ─────────────────────────
logs/
airflow.db
airflow.cfg
standalone_admin_password.txt

# ── Reports (generated at runtime) ────────────────
artifacts/reports/
artifacts/plots/

# ── Docker volumes ─────────────────────────────────
postgres-data/
pgdata/

# ── OS files ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code ───────────────────────────────────────
.vscode/
*.code-workspace

# ── Jupyter checkpoints ───────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Temp test files ───────────────────────────────
test.json
*.tmp

.env
# MLflow local artifact store (auto-generated per run)
artifacts/1/
artifacts/0/

# Evidently drift reports (generated at runtime)
artifacts/reports/*.html